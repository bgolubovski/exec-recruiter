<!DOCTYPE html>
<!--
  prep-meeting.html.template

  Canonical interactive prep packet template for the exec-recruiter plugin's
  phase-4-prep skill. Generated by phase-4-prep at meeting-prep time per role.

  Placeholders use {curly_braces}. Phase-4-prep substitutes them with content
  from: dashboard role entry + meeting-prep-researcher agent output + user inputs.

  Key sections (find by id):
  - #disambiguating  - The scope-disambiguation question (the most important card)
  - #interviewer     - Interviewer profile
  - #founders        - Founder / leadership context
  - #company         - Company origin, funding, customers
  - #anchors         - Tier 1 + Tier 2 anchors (Vector and Compass kept distinct)
  - #ninety-days     - First 90 days narrative (single OR three branched)
  - #questions       - Questions to ask
  - #her-questions   - Likely questions back, one-line answers
  - #comp            - Comp posture
  - #signals         - Friction flags to listen for
  - #wrapup          - Wrap-up signals
  - #donots          - Do nots
  - #logistics       - Logistics + pre-call self-check

  View toggle: Full prep / Call mode (essentials).
  Print-friendly CSS included.
  Persistent checkbox state via sessionStorage.

  Canonical example: outreach/{slug}/prep-sam-meeting.html
-->
<html lang="en">
<head>
<meta charset="UTF-8">
<title>{interviewer_name} · {company} {role_title} · Prep</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
  :root {
    color-scheme: light;
    --bg: #f7f6f3;
    --panel: #ffffff;
    --panel-2: #fafaf7;
    --border: #e5e3dc;
    --border-strong: #cfccc0;
    --text: #1a1a1a;
    --text-dim: #6b6960;
    --text-soft: #8e8b7e;
    --accent: #2a5fb0;
    --accent-soft: #eaf1fb;
    --warn: #b85c00;
    --warn-soft: #fdf2e2;
    --good: #2f7a3a;
    --good-soft: #e8f5ea;
    --critical: #b22a2a;
    --critical-soft: #fbe9e9;
    --code-bg: #f0eee7;
  }
  * { box-sizing: border-box; }
  html, body {
    margin: 0;
    padding: 0;
    background: var(--bg);
    color: var(--text);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", Arial, sans-serif;
    font-size: 15px;
    line-height: 1.55;
  }
  .app {
    display: grid;
    grid-template-columns: 240px minmax(0, 1fr) 280px;
    gap: 16px;
    max-width: 1400px;
    margin: 0 auto;
    padding: 16px;
    min-height: 100vh;
  }
  @media (max-width: 1100px) {
    .app { grid-template-columns: 1fr; }
    .toc, .sidebar { position: static !important; }
  }
  h1 { font-size: 22px; font-weight: 600; margin: 0 0 4px; }
  h2 { font-size: 17px; font-weight: 600; margin: 24px 0 10px; }
  h3 { font-size: 14px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.4px; color: var(--text-dim); margin: 18px 0 8px; }
  h4 { font-size: 14px; font-weight: 600; margin: 14px 0 6px; }
  p { margin: 6px 0 10px; }
  ul, ol { margin: 6px 0 12px; padding-left: 22px; }
  li { margin-bottom: 5px; }
  code { background: var(--code-bg); padding: 1px 5px; border-radius: 3px; font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace; font-size: 13px; }
  a { color: var(--accent); text-decoration: none; }
  a:hover { text-decoration: underline; }
  blockquote {
    margin: 10px 0;
    padding: 10px 14px;
    background: var(--panel-2);
    border-left: 3px solid var(--accent);
    border-radius: 0 6px 6px 0;
    color: var(--text);
    font-style: italic;
  }
  .header {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 16px 18px;
    margin-bottom: 14px;
  }
  .header .subtitle { color: var(--text-dim); font-size: 13px; margin-top: 4px; }
  .header .meta { display: flex; gap: 14px; flex-wrap: wrap; margin-top: 10px; font-size: 12px; color: var(--text-dim); }
  .header .meta .pill { background: var(--panel-2); border: 1px solid var(--border); border-radius: 999px; padding: 3px 10px; }
  .toc {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 14px 14px 16px;
    position: sticky;
    top: 16px;
    align-self: start;
    max-height: calc(100vh - 32px);
    overflow-y: auto;
    font-size: 13px;
  }
  .toc-title { font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-soft); font-weight: 600; margin-bottom: 8px; }
  .toc a { display: block; padding: 4px 0; color: var(--text); border-left: 2px solid transparent; padding-left: 8px; }
  .toc a:hover { color: var(--accent); border-left-color: var(--accent); text-decoration: none; background: var(--accent-soft); }
  .toc a.section { font-weight: 600; margin-top: 8px; }
  .toc a.sub { padding-left: 18px; color: var(--text-dim); font-size: 12px; }
  .main { min-width: 0; }
  .card {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 18px 22px;
    margin-bottom: 14px;
  }
  .card.critical { border-color: var(--critical); background: var(--critical-soft); }
  .card.critical h2 { color: var(--critical); }
  .card.warn { border-color: var(--warn); background: var(--warn-soft); }
  .card.warn h2 { color: var(--warn); }
  .card.good { border-color: var(--good); background: var(--good-soft); }
  .card.good h2 { color: var(--good); }
  details { margin: 10px 0; }
  details summary {
    cursor: pointer;
    padding: 10px 12px;
    background: var(--panel-2);
    border: 1px solid var(--border);
    border-radius: 6px;
    font-weight: 600;
    list-style: none;
  }
  details summary::-webkit-details-marker { display: none; }
  details summary::before { content: "▸ "; color: var(--text-soft); }
  details[open] summary::before { content: "▾ "; }
  details[open] summary { background: var(--accent-soft); border-color: var(--accent); }
  details .details-body { padding: 12px 14px; border: 1px solid var(--border); border-top: 0; border-radius: 0 0 6px 6px; }
  .sidebar {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 14px;
    position: sticky;
    top: 16px;
    align-self: start;
    max-height: calc(100vh - 32px);
    overflow-y: auto;
    font-size: 13px;
  }
  .sidebar h3 { margin-top: 0; }
  .sidebar .glance { font-size: 12px; color: var(--text-dim); margin-bottom: 12px; padding-bottom: 12px; border-bottom: 1px solid var(--border); }
  .sidebar .glance strong { color: var(--text); display: block; margin-bottom: 2px; font-weight: 600; }
  .anchor-list { list-style: none; padding: 0; margin: 0; }
  .anchor-list li { padding: 6px 0; border-bottom: 1px solid var(--border); font-size: 12px; }
  .anchor-list li:last-child { border-bottom: none; }
  .anchor-list .anchor-title { font-weight: 600; }
  .anchor-list .anchor-body { color: var(--text-dim); font-size: 11px; margin-top: 2px; }
  .toggle-bar {
    display: flex;
    gap: 8px;
    margin-bottom: 14px;
    flex-wrap: wrap;
    align-items: center;
  }
  .toggle-bar button {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 6px 14px;
    cursor: pointer;
    font-size: 13px;
    color: var(--text);
    font-family: inherit;
  }
  .toggle-bar button:hover { background: var(--accent-soft); border-color: var(--accent); }
  .toggle-bar button.active { background: var(--accent); color: white; border-color: var(--accent); }
  .toggle-bar .toggle-label { font-size: 12px; color: var(--text-dim); margin-right: 4px; }
  .compact .card-full,
  .compact .card.standard {
    display: none;
  }
  .compact .card.essential {
    display: block;
  }
  .questions { list-style: none; padding: 0; counter-reset: q; }
  .questions li {
    counter-increment: q;
    padding: 10px 14px 10px 38px;
    margin: 6px 0;
    background: var(--panel-2);
    border: 1px solid var(--border);
    border-radius: 6px;
    position: relative;
  }
  .questions li::before {
    content: counter(q);
    position: absolute;
    left: 12px;
    top: 10px;
    background: var(--accent);
    color: white;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    text-align: center;
    font-size: 11px;
    font-weight: 600;
    line-height: 20px;
  }
  .questions li.closer::before { background: var(--critical); }
  .scenario {
    background: var(--panel-2);
    border-left: 3px solid var(--accent);
    border-radius: 0 6px 6px 0;
    padding: 12px 14px;
    margin: 10px 0;
  }
  .scenario-title { font-weight: 600; font-size: 13px; margin-bottom: 6px; color: var(--accent); }
  .scenario blockquote { margin: 0; background: transparent; border-left: 0; padding: 0; font-style: italic; }
  table.kv { width: 100%; border-collapse: collapse; font-size: 13px; margin: 8px 0; }
  table.kv td { padding: 6px 10px; border-bottom: 1px solid var(--border); vertical-align: top; }
  table.kv td:first-child { font-weight: 600; width: 30%; color: var(--text-dim); }
  .footer { padding: 20px 4px; font-size: 12px; color: var(--text-soft); text-align: center; }
  .check-row { display: flex; gap: 8px; align-items: flex-start; margin: 4px 0; font-size: 13px; }
  .check-row input[type=checkbox] { margin-top: 4px; }
  @media print {
    .toc, .sidebar, .toggle-bar { display: none !important; }
    .app { display: block; padding: 0; }
    details { page-break-inside: avoid; }
    details summary { background: transparent !important; border: 0; padding: 0; font-size: 17px; margin-top: 14px; }
    details summary::before { content: "" !important; }
    details[open] .details-body { border: 0; padding: 0; }
    .card { border: 1px solid #ccc; box-shadow: none; }
    .card.critical, .card.warn, .card.good { border-color: #999; background: white !important; }
    body { background: white; font-size: 12px; }
  }
</style>
</head>
<body>
<div class="app">

  <aside class="toc" id="toc">
    <div class="toc-title">Nav</div>
    <a href="#header" class="section">Top</a>
    <a href="#disambiguating" class="section">★ The Disambiguating Question</a>
    <a href="#interviewer" class="section">{interviewer_name}</a>
    <a href="#founders" class="section">Founders + leadership</a>
    <a href="#company" class="section">{company} the company</a>
    <a href="#anchors" class="section">Pattern Anchors</a>
    <a href="#ninety-days" class="section">First 90 Days</a>
    <a href="#questions" class="section">Questions to Ask</a>
    <a href="#her-questions" class="section">Her Likely Questions</a>
    <a href="#comp" class="section">Comp Ask</a>
    <a href="#signals" class="section">Signals to Listen For</a>
    <a href="#wrapup" class="section">Wrap-Up Signals</a>
    <a href="#donots" class="section">Do Nots</a>
    <a href="#logistics" class="section">Logistics</a>
    <a href="#sources" class="section">Sources</a>
  </aside>

  <main class="main" id="main">

    <div class="header card" id="header">
      <h1>{interviewer_name} · {company} {role_title} · {round_label} Prep</h1>
      <div class="subtitle">{header_subtitle}</div>
      <div class="meta">
        <span class="pill">Format: {meeting_format}</span>
        <span class="pill">Status: {dashboard_status}</span>
        <span class="pill">Tier: {tier}</span>
        <span class="pill">Score: {score}</span>
        <span class="pill"><a href="{booking_link}" target="_blank">{booking_link_label}</a></span>
        <span class="pill"><a href="{ats_url}" target="_blank">{ats_label}</a></span>
      </div>
    </div>

    <div class="toggle-bar">
      <span class="toggle-label">View:</span>
      <button id="btn-full" class="active">Full prep</button>
      <button id="btn-compact">Call mode (essentials)</button>
      <button id="btn-print" onclick="window.print()">Print / PDF</button>
    </div>


    <div class="card critical essential" id="disambiguating">
      <h2>★ The Disambiguating Question (ask early, peer-to-peer)</h2>
      <blockquote>
        "{primary_disambiguation_question}"
      </blockquote>
      <p>{disambiguation_rationale}</p>
      <table class="kv">
        <tr><td>Backup variant 1</td><td>"{backup_variant_1}"</td></tr>
        <tr><td>Backup variant 2</td><td>"{backup_variant_2}"</td></tr>
      </table>
      <p><strong>Why this matters:</strong> {disambiguation_why}</p>
    </div>

    <div class="card essential" id="interviewer">
      <h2>{interviewer_name}</h2>
      <p><a href="{interviewer_linkedin_url}" target="_blank">{interviewer_linkedin_short}</a> · {interviewer_location} · {interviewer_current_title} · reports to {interviewer_reports_to}</p>

      <h3>Career arc (most-relevant-first)</h3>
      <ul>{interviewer_career_arc}</ul>

      <h3>Education</h3>
      <ul>{interviewer_education}</ul>

      <h3>Signals to probe and use</h3>
      <ul>{interviewer_signals_to_probe}</ul>

      <h3>Signals to avoid</h3>
      <ul>{interviewer_signals_to_avoid}</ul>

      <h3>Title conflicts (if any)</h3>
      <p>{interviewer_title_conflicts}</p>

      <h3>Reading note</h3>
      <p>{interviewer_reading_note}</p>
    </div>

    <div class="card standard" id="founders">
      <h2>Founders / leadership context</h2>

      <details open>
        <summary>{founder_1_name} — {founder_1_title}</summary>
        <div class="details-body">
          <p><a href="{founder_1_linkedin}" target="_blank">{founder_1_linkedin_short}</a></p>
          <ul>{founder_1_signals}</ul>
          <p><strong>Reading note:</strong> {founder_1_reading_note}</p>
        </div>
      </details>

      <details>
        <summary>{founder_2_name} — {founder_2_title}</summary>
        <div class="details-body">
          <ul>{founder_2_signals}</ul>
          <p><strong>Reading note:</strong> {founder_2_reading_note}</p>
        </div>
      </details>

      <details>
        <summary>Founder dynamic</summary>
        <div class="details-body">
          <p>{founder_dynamic_note}</p>
        </div>
      </details>
    </div>

    <div class="card standard" id="company">
      <h2>{company} the company</h2>

      <details open>
        <summary>Origin and pivots</summary>
        <div class="details-body">
          <ul>{company_origin_bullets}</ul>
        </div>
      </details>

      <details>
        <summary>Funding (refreshed)</summary>
        <div class="details-body">
          <ul>{company_funding_bullets}</ul>
        </div>
      </details>

      <details>
        <summary>Anchor case study — {anchor_customer_name}</summary>
        <div class="details-body">
          <ul>{anchor_case_study_bullets}</ul>
        </div>
      </details>

      <details>
        <summary>Distribution / market access</summary>
        <div class="details-body">
          <p>{distribution_note}</p>
        </div>
      </details>

      <details>
        <summary>Stage shape signals</summary>
        <div class="details-body">
          <ul>{stage_shape_bullets}</ul>
        </div>
      </details>
    </div>

    <div class="card essential" id="anchors">
      <h2>Your pattern-match anchors (lead with these, in this order — keep distinct-layer ventures separate, do not conflate)</h2>
      <ol>
        <li><strong>{anchor_1_name}.</strong> {anchor_1_description} <em>Maps to:</em> {anchor_1_map_to}.</li>
        <li><strong>{anchor_2_name}.</strong> {anchor_2_description} <em>Maps to:</em> {anchor_2_map_to}.</li>
        <li><strong>{anchor_3_name}.</strong> {anchor_3_description} <em>Maps to:</em> {anchor_3_map_to}.</li>
        <li><strong>{anchor_4_name}.</strong> {anchor_4_description} <em>Maps to:</em> {anchor_4_map_to}.</li>
        <li><strong>{anchor_5_name}.</strong> {anchor_5_description} <em>Maps to:</em> {anchor_5_map_to}.</li>
      </ol>

      <h3>Tier 2 anchors (use only if she/he probes)</h3>
      <ul>{tier_2_anchors_bullets}</ul>
    </div>

    <div class="card standard" id="ninety-days">
      <h2>First 90 Days (when she/he asks)</h2>
      <p>{ninety_days_intro}</p>

      <div class="scenario">
        <div class="scenario-title">{scenario_1_title}</div>
        <blockquote>"{scenario_1_narrative}"</blockquote>
      </div>

      <div class="scenario">
        <div class="scenario-title">{scenario_2_title}</div>
        <blockquote>"{scenario_2_narrative}"</blockquote>
      </div>

      <div class="scenario">
        <div class="scenario-title">{scenario_3_title}</div>
        <blockquote>"{scenario_3_narrative}"</blockquote>
      </div>
    </div>

    <div class="card essential" id="questions">
      <h2>Questions to ask {interviewer_first_name}</h2>
      <p>Pick 3-4. The point is to demonstrate operator-mindset, not interrogate.</p>
      <ol class="questions">
        <li>{question_1}</li>
        <li>{question_2}</li>
        <li>{question_3}</li>
        <li>{question_4}</li>
        <li>{question_5}</li>
        <li>{question_6}</li>
        <li class="closer"><strong>Closer:</strong> {question_closer}</li>
      </ol>
    </div>

    <div class="card standard" id="her-questions">
      <h2>Questions she/he is likely to ask you — one-line answers</h2>
      <table class="kv">
        <tr><td>"Walk me through your background."</td><td>{answer_background}</td></tr>
        <tr><td>"Why {company}?"</td><td>{answer_why_company}</td></tr>
        <tr><td>"What attracts you about this stage?"</td><td>{answer_stage}</td></tr>
        <tr><td>"Question for us up front?"</td><td>{answer_question_back}</td></tr>
        <tr><td>"AI product experience?"</td><td>{answer_ai_experience}</td></tr>
        <tr><td>"{domain} experience?"</td><td>{answer_domain_experience}</td></tr>
        <tr><td>"Comp expectations?"</td><td>See Comp Ask section.</td></tr>
        <tr><td>"Timeline?"</td><td>{answer_timeline}</td></tr>
      </table>
    </div>

    <div class="card warn essential" id="comp">
      <h2>Comp ask (only if she/he surfaces it)</h2>
      <p>{comp_context}</p>
      <blockquote>"{comp_one_liner}"</blockquote>
      <p><strong>Do NOT volunteer a hard floor on the first call.</strong> {comp_rationale}</p>
    </div>

    <div class="card essential" id="signals">
      <h2>Friction flags to listen for</h2>
      <table class="kv">{friction_flags_rows}</table>
    </div>

    <div class="card standard" id="wrapup">
      <h2>Wrap-up signals to send by minute 25-30</h2>
      <ol>{wrap_up_bullets}</ol>
    </div>

    <div class="card critical standard" id="donots">
      <h2>Do Nots</h2>
      <ul>{do_nots_bullets}</ul>
    </div>

    <div class="card standard" id="logistics">
      <h2>Logistics</h2>
      <table class="kv">{logistics_rows}</table>

      <h3>Pre-call self-check</h3>
      <div class="check-row"><input type="checkbox"> Booked time on calendar</div>
      <div class="check-row"><input type="checkbox"> Re-read the JD body the day before</div>
      <div class="check-row"><input type="checkbox"> Reviewed interviewer LinkedIn for new posts / changes</div>
      <div class="check-row"><input type="checkbox"> Reviewed anchor case study (one-line ready to cite)</div>
      <div class="check-row"><input type="checkbox"> Decided which 3-4 questions to ask</div>
      <div class="check-row"><input type="checkbox"> Practiced 60-second background pitch</div>
      <div class="check-row"><input type="checkbox"> Comp range stance rehearsed</div>
      <div class="check-row"><input type="checkbox"> Quiet room, good audio, video on, water nearby</div>
    </div>

    <div class="card standard" id="sources">
      <h2>Sources</h2>
      <ul>{sources_bullets}</ul>
    </div>

    <div class="footer">Prep packet built {build_date} · Saved alongside application materials in outreach/{slug}/</div>

  </main>

  <aside class="sidebar" id="sidebar">
    <h3>At a Glance</h3>
    <div class="glance">
      <strong>The Question</strong>
      {sidebar_question_summary}
    </div>
    <div class="glance">
      <strong>Tone</strong>
      {sidebar_tone}
    </div>
    <div class="glance">
      <strong>What NOT to claim</strong>
      {sidebar_do_not_claim}
    </div>

    <h3>Lead Anchors</h3>
    <ul class="anchor-list">
      <li>
        <div class="anchor-title">{anchor_1_name}</div>
        <div class="anchor-body">{anchor_1_short}</div>
      </li>
      <li>
        <div class="anchor-title">{anchor_2_name}</div>
        <div class="anchor-body">{anchor_2_short}</div>
      </li>
      <li>
        <div class="anchor-title">{anchor_3_name}</div>
        <div class="anchor-body">{anchor_3_short}</div>
      </li>
      <li>
        <div class="anchor-title">{anchor_4_name}</div>
        <div class="anchor-body">{anchor_4_short}</div>
      </li>
      <li>
        <div class="anchor-title">{anchor_5_name}</div>
        <div class="anchor-body">{anchor_5_short}</div>
      </li>
    </ul>

    <h3>Comp Stance</h3>
    <div class="glance" style="border-bottom: 0; margin-bottom: 0; padding-bottom: 0;">
      <strong>If asked:</strong>
      {sidebar_comp_stance}
    </div>
  </aside>

</div>

<script>
  const main = document.getElementById('main');
  const btnFull = document.getElementById('btn-full');
  const btnCompact = document.getElementById('btn-compact');
  btnFull.addEventListener('click', () => {
    main.classList.remove('compact');
    btnFull.classList.add('active');
    btnCompact.classList.remove('active');
  });
  btnCompact.addEventListener('click', () => {
    main.classList.add('compact');
    btnCompact.classList.add('active');
    btnFull.classList.remove('active');
  });

  document.querySelectorAll('.toc a').forEach(a => {
    a.addEventListener('click', (e) => {
      const targetId = a.getAttribute('href').slice(1);
      const target = document.getElementById(targetId);
      if (target) {
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  document.querySelectorAll('input[type=checkbox]').forEach((cb, i) => {
    const key = 'prep-check-' + i;
    try {
      cb.checked = sessionStorage.getItem(key) === '1';
      cb.addEventListener('change', () => {
        sessionStorage.setItem(key, cb.checked ? '1' : '0');
      });
    } catch (e) { /* sessionStorage may be unavailable */ }
  });
</script>

</body>
</html>
